# WordPress GraphQL endpoint
WORDPRESS_API_URL=https://dottotv.ro/graphql

# Claude API key pentru generare SEO automată
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# URL-ul site-ului pentru SEO
NEXT_PUBLIC_SITE_URL=https://dottotv.ro

# Stream URL pentru Live TV (HLS)
NEXT_PUBLIC_LIVE_STREAM_URL=https://stream.dottotv.ro/live/stream.m3u8

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# SMTP — trimitere emailuri formulare de contact
SMTP_HOST=mail.dottotv.ro
SMTP_PORT=465
SMTP_USER=office@dottotv.ro
SMTP_PASS=your_smtp_password_here
